    "        \"PROGRAMAS/EN LA RAYA/En la Raya Deportes- Septiembre 29 de 2025.mp3\",\n",
    "        \"PROGRAMAS/DEJAME SER ARTE/PROGRAMAS/DEJAME SER ARTE 03-07-25.mp3\",\n",
    "        \"PROGRAMAS/DEJAME SER ARTE/PROGRAMAS/DSA 02-10-25.mp3\",\n",
