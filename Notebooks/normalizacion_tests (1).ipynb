    "        \"PROGRAMAS/ENTRE NOSOTROS/PROGRAMA 286 ENTRE NOSOTROS DE KAREN A.mp3\",\n",
    "    ]\n",
    "\n",
    "    base = Path(ruta_base)\n",
    "\n",
    "    # Crear carpetas\n",
    "    for carpeta in carpetas:\n",
